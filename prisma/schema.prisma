generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Barberia {
  id          String   @id @default(cuid())
  nombre      String
  subdominio  String   @unique
  slogan      String?
  descripcion String?
  direccion   String?
  telefono    String?
  email       String   @unique
  password    String
  plan        Plan     @default(STARTER)
  activa      Boolean  @default(true)
  creadaEn    DateTime @default(now())

  // Personalización del sitio
  colorPrimario    String?  @default("#C9A84C")
  colorSecundario  String?  @default("#1C1C1E")
  colorFondo       String?  @default("#0D0D0D")
  colorTexto       String?  @default("#FFFFFF")
  logoUrl          String?
  heroFotoUrl      String?
  heroTitulo       String?
  heroDescripcion  String?

  barberos  Barbero[]
  servicios Servicio[]
  turnos    Turno[]
}

// ── BARBERO ───────────────────────────────────────────────
model Barbero {
  id           String   @id @default(cuid())
  nombre       String
  usuario      String   // nombre de usuario para login
  pin          String   // PIN de 6 digitos hasheado
  especialidad String?
  foto         String?
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())
  insumos     InsumoBarbero[]

  barberiaId   String
  barberia     Barberia @relation(fields: [barberiaId], references: [id])

  horarios          Horario[]
  horariosBloqueados HorarioBloqueado[]
  turnos            Turno[]
  gastos            GastoBarbero[]

  @@unique([usuario, barberiaId])
}

// ── HORARIO ───────────────────────────────────────────────
model Horario {
  id        String  @id @default(cuid())
  diaSemana Int
  desde     String
  hasta     String
  activo    Boolean @default(true)

  barberoId String
  barbero   Barbero @relation(fields: [barberoId], references: [id])
}

// ── HORARIO BLOQUEADO ─────────────────────────────────────
model HorarioBloqueado {
  id     String   @id @default(cuid())
  fecha  DateTime
  motivo String?

  barberoId String
  barbero   Barbero @relation(fields: [barberoId], references: [id])
}

// ── SERVICIO ──────────────────────────────────────────────
model Servicio {
  id          String  @id @default(cuid())
  nombre      String
  descripcion String?
  precio      Int
  duracion    Int
  color       String  @default("#C9A84C")
  activo      Boolean @default(true)

  barberiaId  String
  barberia    Barberia @relation(fields: [barberiaId], references: [id])

  turnos      Turno[]
}

// ── TURNO ─────────────────────────────────────────────────
model Turno {
  id              String      @id @default(cuid())
  fecha           DateTime
  estado          EstadoTurno @default(PENDIENTE)
  clienteNombre   String
  clienteEmail    String
  clienteTelefono String?
  notas           String?
  creadoEn        DateTime    @default(now())

  barberiaId  String
  barberia    Barberia @relation(fields: [barberiaId], references: [id])

  barberoId   String
  barbero     Barbero  @relation(fields: [barberoId], references: [id])

  servicioId  String
  servicio    Servicio @relation(fields: [servicioId], references: [id])
}

// ── GASTO BARBERO ─────────────────────────────────────────
model GastoBarbero {
  id        String            @id @default(cuid())
  nombre    String
  monto     Int
  categoria CategoriaGasto
  fecha     DateTime          @default(now())

  barberoId String
  barbero   Barbero @relation(fields: [barberoId], references: [id])
}

// ── INSUMO DEL BARBERO ────────────────────────────────────────────────────────
model InsumoBarbero {
  id          String        @id @default(cuid())
  nombre      String
  tipo        TipoInsumo
  // Para tipo PORCENTAJE
  porcentaje  Float?
  // Para tipo UNIDAD (ej: gramos de cera)
  precioTotal Float?        // precio del envase/paquete completo
  cantidadTotal Float?      // total de unidades (ej: 100g)
  cantidadPorCorte Float?   // cuanto se usa por corte (ej: 2g)
  unidad      String?       // "g", "ml", "unidad", etc.
  // Para tipo FIJO
  montoFijo   Float?
  // Para tipo AMORTIZACION
  precioMaquina Float?      // precio de compra de la maquina
  cortesDeVida  Int?        // cantidad de cortes de vida util
  creadoEn    DateTime      @default(now())

  barberoId   String
  barbero     Barbero       @relation(fields: [barberoId], references: [id])

  servicios   InsumoServicio[]
}

// ── RELACION INSUMO-SERVICIO ──────────────────────────────────────────────────
model InsumoServicio {
  id          String        @id @default(cuid())
  insumoId    String
  insumo      InsumoBarbero @relation(fields: [insumoId], references: [id])
  servicioId  String
  // No relacionamos con Servicio directamente porque es de la barberia
  // guardamos el id para filtrar
}

// ── ENUMS ─────────────────────────────────────────────────
enum Plan {
  STARTER
  PRO
  PREMIUM
}

enum EstadoTurno {
  PENDIENTE
  CONFIRMADO
  EN_CURSO
  COMPLETADO
  CANCELADO
}

enum CategoriaGasto {
  HERRAMIENTAS
  PRODUCTOS
  TRANSPORTE
  COMIDA
  ROPA
  OTROS
}

enum TipoInsumo {
  PORCENTAJE
  UNIDAD
  FIJO
  AMORTIZACION
}